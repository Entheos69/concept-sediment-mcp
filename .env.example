# Concept Sediment MCP Server — Environment Variables
#
# Copiar a .env para desarrollo local:
#   cp .env.example .env
#
# En Railway: configurar como variables de entorno del servicio

# ═══════════════════════════════════════════════════════════
# REQUERIDAS
# ═══════════════════════════════════════════════════════════

# PostgreSQL (misma instancia que concept-sediment Django)
DATABASE_URL=postgresql://user:password@host:port/concept_sediment

# OpenAI API Key (para búsqueda semántica por embeddings)
OPENAI_API_KEY=sk-proj-your-key-here

# ═══════════════════════════════════════════════════════════
# OPCIONALES
# ═══════════════════════════════════════════════════════════

# Puerto del servidor (Railway inyecta PORT automáticamente)
# MCP_PORT=8000

# Host (default: 0.0.0.0 para aceptar conexiones externas)
# MCP_HOST=0.0.0.0

# Modelo de embeddings (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small
